# ─────────────────────────────────────────────────────────────
# Company Brain — environment. Copy to .env and fill in.
# Secrets live here only; never commit a real .env.
# ─────────────────────────────────────────────────────────────

# Core ----------------------------------------------------------
NODE_ENV=development
# Structured-logger level: debug | info | warn | error
LOG_LEVEL=info
# Postgres with the pgvector extension (see docker-compose.yml for local).
DATABASE_URL=postgres://brain:brain@localhost:5432/company_brain

# AI ------------------------------------------------------------
# Which chat provider to use for judging/extraction: "anthropic", "gemini", or "openai".
# Only the selected provider's API key is required.
AI_PROVIDER=gemini

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_CHEAP=claude-haiku-4-5-20251001

# Gemini (used when AI_PROVIDER=gemini) — Google Generative Language API.
# Set GEMINI_MODEL to the exact id Google gives you (e.g. gemini-3.5-flash).
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_CHEAP=gemini-3.5-flash

# OpenAI chat (used when AI_PROVIDER=openai) — reuses OPENAI_API_KEY below.
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_CHAT_MODEL_CHEAP=gpt-4o-mini

# Embeddings ----------------------------------------------------
# Provider: "voyage" (default), "openai", or "gemini".
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSIONS=1024
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
# gemini-embedding-001 supports outputDimensionality (matches EMBEDDING_DIMENSIONS).
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# GitHub App ----------------------------------------------------
GITHUB_APP_ID=123456
# Private key PEM. Either inline (with literal \n) or a path via GITHUB_APP_PRIVATE_KEY_PATH.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_PRIVATE_KEY_PATH=./github-app.private-key.pem
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret
GITHUB_APP_SLUG=company-brain

# GitHub OAuth (dashboard login via Auth.js) --------------------
GITHUB_CLIENT_ID=Iv1....
GITHUB_CLIENT_SECRET=...

# Auth.js -------------------------------------------------------
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Token encryption at rest (AES-256-GCM key, 32 bytes base64) ---
TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# App ----------------------------------------------------------
APP_BASE_URL=http://localhost:3000
# Safety rail: during development the bot only ever comments on this repo.
ALLOWLIST_REPOS=gumballchief/pr-bot-test

# MCP / Preflight CLI (optional) --------------------------------
# Repo slug (owner/name) the Preflight CLI resolves against. If empty,
# it's derived from `git remote get-url origin`.
COMPANY_BRAIN_REPO=
# Path to the repo the CLI should operate on. Defaults to the current
# working directory when empty.
COMPANY_BRAIN_REPO_PATH=

# Scheduled sweeps (pg-boss cron, UTC; optional — defaults shown) -----
# Re-check every open PR (decisions/dismissals drift between pushes).
RESCAN_CRON=0 */6 * * *
# Re-extract + consolidate each repo's memory from merged history.
REFRESH_CRON=0 3 * * *

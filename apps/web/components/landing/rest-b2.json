{"html":"\n\n  \n  <section data-dc-tpl=\"449\" id=\"benefits\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 130px 24px 0px;\">\n    <div data-dc-tpl=\"450\" style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 34px; align-items: center;\">\n      <div data-dc-tpl=\"451\">\n        <div data-dc-tpl=\"452\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7fb0f2);\">05 — Why it compounds</div>\n        <h2 data-dc-tpl=\"453\" data-reveal=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(30px, 4.2vw, 50px); line-height: 1.06; letter-spacing: -0.025em; margin: 16px 0px 0px; color: rgb(27, 23, 38);\">Context that gets more valuable as you grow</h2>\n        <p data-dc-tpl=\"454\" data-reveal=\"\" style=\"font-size: 17px; line-height: 1.6; color: rgb(86, 81, 99); margin: 16px 0px 0px; max-width: 52ch;\">Current AI tools understand programming. Company Brain understands <em data-dc-tpl=\"455\" style=\"font-style: normal; color: rgb(86, 81, 99);\">your company</em> — and every decision it captures makes the next one sharper.</p>\n      </div>\n      <div data-dc-tpl=\"456\" style=\"display: flex; flex-direction: column; gap: 12px;\">\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Humans see only clean code</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: rgb(111, 106, 125);\"><span class=\"sc-interp\">Validated, standards-compliant changes — not another review pile.</span></div>\n            </div>\n          </div>\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Fewer review cycles</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: rgb(111, 106, 125);\"><span class=\"sc-interp\">Mistakes are caught and fixed before the PR is even opened.</span></div>\n            </div>\n          </div>\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Standards enforced automatically</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: rgb(111, 106, 125);\"><span class=\"sc-interp\">Your conventions apply on every change without anyone policing them.</span></div>\n            </div>\n          </div>\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Memory that compounds</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: rgb(111, 106, 125);\"><span class=\"sc-interp\">Every decision captured makes the next one faster and safer.</span></div>\n            </div>\n          </div>\n        \n      </div>\n    </div>\n  </section>\n\n  \n  <section data-dc-tpl=\"465\" id=\"usecases\" style=\"position: relative; z-index: 1; scroll-snap-align: none;\">\n    <div data-dc-tpl=\"466\" data-vpin-outer=\"\" style=\"position: relative; height: 420vh;\">\n      <div data-dc-tpl=\"467\" style=\"position: sticky; top: 0px; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; overflow: hidden; max-width: 900px; margin: 0px auto; padding: 88px 24px 44px;\">\n        <div data-dc-tpl=\"468\" style=\"text-align: center;\">\n          <div data-dc-tpl=\"469\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7c5cff);\">06 — Use cases</div>\n          <h2 data-dc-tpl=\"470\" data-reveal=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(28px, 4vw, 48px); line-height: 1.06; letter-spacing: -0.025em; margin: 14px 0px 0px; color: rgb(27, 23, 38);\">Put your engineering memory to work</h2>\n        </div>\n        <div data-dc-tpl=\"471\" style=\"margin-top: 32px; display: flex; flex-direction: column; gap: 14px;\">\n          \n            <div data-dc-tpl=\"473\" data-vcard=\"\" style=\"position: relative; border-radius: 20px; border: 1px solid rgba(255, 111, 94, 0.4); background: linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.72)); overflow: hidden; transition: border-color 0.5s, box-shadow 0.5s, background 0.5s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); backdrop-filter: blur(10px); box-shadow: rgba(124, 92, 255, 0.4) 0px 30px 70px -34px; transform: scale(1); \">\n              <div data-dc-tpl=\"474\" data-vcard-glow=\"\" style=\"position: absolute; top: -40%; right: -8%; width: 280px; height: 280px; border-radius: 50%; background: radial-gradient(circle,var(--acc,#4f7ef7),transparent 66%); opacity: 0.5; filter: blur(18px); pointer-events: none; transition: opacity 0.5s;\"></div>\n              <div data-dc-tpl=\"475\" style=\"position: relative; display: flex; align-items: center; gap: 16px; padding: 22px 26px;\">\n                <div data-dc-tpl=\"476\" data-vcard-no=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 700; font-size: 24px; line-height: 1; color: var(--acc,#ff6f5e); transition: color 0.5s; min-width: 38px;\"><span class=\"sc-interp\">01</span></div>\n                <div data-dc-tpl=\"477\" style=\"flex: 1 1 0%;\">\n                  <div data-dc-tpl=\"478\" data-vcard-tag=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 11px; letter-spacing: 0.1em; color: var(--acc2,#7c5cff); transition: color 0.5s;\"><span class=\"sc-interp\">ONBOARDING</span></div>\n                  <h3 data-dc-tpl=\"479\" data-vcard-title=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(18px, 2.2vw, 24px); margin: 4px 0px 0px; color: rgb(27, 23, 38); letter-spacing: -0.015em;\"><span class=\"sc-interp\">Ramp new engineers in days</span></h3>\n                </div>\n                <div data-dc-tpl=\"480\" data-vcard-dot=\"\" style=\"width: 10px; height: 10px; border-radius: 50%; background: var(--acc,#ff6f5e); transition: background 0.5s, box-shadow 0.5s, transform 0.5s; box-shadow: 0 0 12px var(--acc,#ff6f5e); transform: scale(1.3);\"></div>\n              </div>\n              <div data-dc-tpl=\"481\" data-vcard-reveal=\"\" style=\"max-height: 220px;  overflow: hidden; transition: max-height 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s;\">\n                <p data-dc-tpl=\"482\" style=\"margin: 0px; padding: 0px 26px 24px 80px; font-size: 15.5px; line-height: 1.62; color: rgb(107, 102, 120);\"><span class=\"sc-interp\">New hires — and their agents — inherit years of context instantly instead of learning it the hard way.</span></p>\n              </div>\n            </div>\n          \n            <div data-dc-tpl=\"473\" data-vcard=\"\" style=\"position: relative; border-radius: 20px; border: 1px solid rgba(28, 20, 45, 0.08); background: linear-gradient(160deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5)); overflow: hidden; transition: border-color 0.5s, box-shadow 0.5s, background 0.5s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); backdrop-filter: blur(10px); box-shadow: none; transform: scale(0.985); opacity: 0.62;\">\n              <div data-dc-tpl=\"474\" data-vcard-glow=\"\" style=\"position: absolute; top: -40%; right: -8%; width: 280px; height: 280px; border-radius: 50%; background: radial-gradient(circle,var(--acc,#4f7ef7),transparent 66%); opacity: 0; filter: blur(18px); pointer-events: none; transition: opacity 0.5s;\"></div>\n              <div data-dc-tpl=\"475\" style=\"position: relative; display: flex; align-items: center; gap: 16px; padding: 22px 26px;\">\n                <div data-dc-tpl=\"476\" data-vcard-no=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 700; font-size: 24px; line-height: 1; color: rgba(28, 20, 45, 0.18); transition: color 0.5s; min-width: 38px;\"><span class=\"sc-interp\">02</span></div>\n                <div data-dc-tpl=\"477\" style=\"flex: 1 1 0%;\">\n                  <div data-dc-tpl=\"478\" data-vcard-tag=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 11px; letter-spacing: 0.1em; color: rgb(123, 118, 137); transition: color 0.5s;\"><span class=\"sc-interp\">AI GUARDRAILS</span></div>\n                  <h3 data-dc-tpl=\"479\" data-vcard-title=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(18px, 2.2vw, 24px); margin: 4px 0px 0px; color: rgb(27, 23, 38); letter-spacing: -0.015em;\"><span class=\"sc-interp\">Safe autonomy for agents</span></h3>\n                </div>\n                <div data-dc-tpl=\"480\" data-vcard-dot=\"\" style=\"width: 10px; height: 10px; border-radius: 50%; background: rgba(28, 20, 45, 0.14); transition: background 0.5s, box-shadow 0.5s, transform 0.5s; box-shadow: none; transform: scale(1);\"></div>\n              </div>\n              <div data-dc-tpl=\"481\" data-vcard-reveal=\"\" style=\"max-height: 0px; opacity: 0; overflow: hidden; transition: max-height 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s;\">\n                <p data-dc-tpl=\"482\" style=\"margin: 0px; padding: 0px 26px 24px 80px; font-size: 15.5px; line-height: 1.62; color: rgb(107, 102, 120);\"><span class=\"sc-interp\">Let Cursor and Claude Code move fast while Company Brain keeps every change inside your rules.</span></p>\n              </div>\n            </div>\n          \n            <div data-dc-tpl=\"473\" data-vcard=\"\" style=\"position: relative; border-radius: 20px; border: 1px solid rgba(28, 20, 45, 0.08); background: linear-gradient(160deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5)); overflow: hidden; transition: border-color 0.5s, box-shadow 0.5s, background 0.5s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); backdrop-filter: blur(10px); box-shadow: none; transform: scale(0.985); opacity: 0.62;\">\n              <div data-dc-tpl=\"474\" data-vcard-glow=\"\" style=\"position: absolute; top: -40%; right: -8%; width: 280px; height: 280px; border-radius: 50%; background: radial-gradient(circle,var(--acc,#4f7ef7),transparent 66%); opacity: 0; filter: blur(18px); pointer-events: none; transition: opacity 0.5s;\"></div>\n              <div data-dc-tpl=\"475\" style=\"position: relative; display: flex; align-items: center; gap: 16px; padding: 22px 26px;\">\n                <div data-dc-tpl=\"476\" data-vcard-no=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 700; font-size: 24px; line-height: 1; color: rgba(28, 20, 45, 0.18); transition: color 0.5s; min-width: 38px;\"><span class=\"sc-interp\">03</span></div>\n                <div data-dc-tpl=\"477\" style=\"flex: 1 1 0%;\">\n                  <div data-dc-tpl=\"478\" data-vcard-tag=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 11px; letter-spacing: 0.1em; color: rgb(123, 118, 137); transition: color 0.5s;\"><span class=\"sc-interp\">ARCHITECTURE</span></div>\n                  <h3 data-dc-tpl=\"479\" data-vcard-title=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(18px, 2.2vw, 24px); margin: 4px 0px 0px; color: rgb(27, 23, 38); letter-spacing: -0.015em;\"><span class=\"sc-interp\">Preserve hard-won decisions</span></h3>\n                </div>\n                <div data-dc-tpl=\"480\" data-vcard-dot=\"\" style=\"width: 10px; height: 10px; border-radius: 50%; background: rgba(28, 20, 45, 0.14); transition: background 0.5s, box-shadow 0.5s, transform 0.5s; box-shadow: none; transform: scale(1);\"></div>\n              </div>\n              <div data-dc-tpl=\"481\" data-vcard-reveal=\"\" style=\"max-height: 0px; opacity: 0; overflow: hidden; transition: max-height 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s;\">\n                <p data-dc-tpl=\"482\" style=\"margin: 0px; padding: 0px 26px 24px 80px; font-size: 15.5px; line-height: 1.62; color: rgb(107, 102, 120);\"><span class=\"sc-interp\">Rejected approaches and ADRs stay enforced long after the people who made them move on.</span></p>\n              </div>\n            </div>\n          \n            <div data-dc-tpl=\"473\" data-vcard=\"\" style=\"position: relative; border-radius: 20px; border: 1px solid rgba(28, 20, 45, 0.08); background: linear-gradient(160deg, rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5)); overflow: hidden; transition: border-color 0.5s, box-shadow 0.5s, background 0.5s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); backdrop-filter: blur(10px); box-shadow: none; transform: scale(0.985); opacity: 0.62;\">\n              <div data-dc-tpl=\"474\" data-vcard-glow=\"\" style=\"position: absolute; top: -40%; right: -8%; width: 280px; height: 280px; border-radius: 50%; background: radial-gradient(circle,var(--acc,#4f7ef7),transparent 66%); opacity: 0; filter: blur(18px); pointer-events: none; transition: opacity 0.5s;\"></div>\n              <div data-dc-tpl=\"475\" style=\"position: relative; display: flex; align-items: center; gap: 16px; padding: 22px 26px;\">\n                <div data-dc-tpl=\"476\" data-vcard-no=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 700; font-size: 24px; line-height: 1; color: rgba(28, 20, 45, 0.18); transition: color 0.5s; min-width: 38px;\"><span class=\"sc-interp\">04</span></div>\n                <div data-dc-tpl=\"477\" style=\"flex: 1 1 0%;\">\n                  <div data-dc-tpl=\"478\" data-vcard-tag=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 11px; letter-spacing: 0.1em; color: rgb(123, 118, 137); transition: color 0.5s;\"><span class=\"sc-interp\">RELIABILITY</span></div>\n                  <h3 data-dc-tpl=\"479\" data-vcard-title=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(18px, 2.2vw, 24px); margin: 4px 0px 0px; color: rgb(27, 23, 38); letter-spacing: -0.015em;\"><span class=\"sc-interp\">Stop repeat incidents</span></h3>\n                </div>\n                <div data-dc-tpl=\"480\" data-vcard-dot=\"\" style=\"width: 10px; height: 10px; border-radius: 50%; background: rgba(28, 20, 45, 0.14); transition: background 0.5s, box-shadow 0.5s, transform 0.5s; box-shadow: none; transform: scale(1);\"></div>\n              </div>\n              <div data-dc-tpl=\"481\" data-vcard-reveal=\"\" style=\"max-height: 0px; opacity: 0; overflow: hidden; transition: max-height 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s;\">\n                <p data-dc-tpl=\"482\" style=\"margin: 0px; padding: 0px 26px 24px 80px; font-size: 15.5px; line-height: 1.62; color: rgb(107, 102, 120);\"><span class=\"sc-interp\">Once an incident teaches a lesson, that lesson is enforced on every future change automatically.</span></p>\n              </div>\n            </div>\n          \n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section data-dc-tpl=\"483\" id=\"pricing\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 130px 24px 0px; text-align: center;\">\n    <div data-dc-tpl=\"484\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7fb0f2);\">07 — Pricing</div>\n    <h2 data-dc-tpl=\"485\" data-reveal=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.06; letter-spacing: -0.025em; margin: 16px auto 0px; color: rgb(27, 23, 38);\">Start free. Scale when it pays for itself.</h2>\n\n    <div data-dc-tpl=\"486\" data-reveal=\"\" style=\"margin: 28px auto 0px; display: inline-flex; align-items: center; gap: 4px; padding: 5px; border-radius: 12px; border: 1px solid rgba(28, 20, 45, 0.1); background: rgba(255, 255, 255, 0.6);\">\n      <button data-dc-tpl=\"487\" style=\"padding: 11px 18px; border-radius: 9px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; cursor: pointer; font-family: var(--font-inter-tight), 
{"html":"\n\n  \n  <section data-dc-tpl=\"449\" id=\"benefits\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 130px 24px 0px;\">\n    <div data-dc-tpl=\"450\" style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 34px; align-items: center;\">\n      <div data-dc-tpl=\"451\">\n        <div data-dc-tpl=\"452\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7fb0f2);\">05 — Why it compounds</div>\n        <h2 data-dc-tpl=\"453\" data-reveal=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(30px, 4.2vw, 50px); line-height: 1.06; letter-spacing: -0.025em; margin: 16px 0px 0px; color: var(--l-ink);\">Context that gets more valuable as you grow</h2>\n        <p data-dc-tpl=\"454\" data-reveal=\"\" style=\"font-size: 17px; line-height: 1.6; color: var(--l-body); margin: 16px 0px 0px; max-width: 52ch;\">Current AI tools understand programming. Slovey understands <em data-dc-tpl=\"455\" style=\"font-style: normal; color: var(--l-body);\">your company</em> — and every decision it captures makes the next one sharper.</p>\n      </div>\n      <div data-dc-tpl=\"456\" style=\"display: flex; flex-direction: column; gap: 12px;\">\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid var(--l-border-soft); background: linear-gradient(var(--l-card), var(--l-card-faint));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Humans see only clean code</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: var(--l-muted);\"><span class=\"sc-interp\">Validated, standards-compliant changes — not another review pile.</span></div>\n            </div>\n          </div>\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid var(--l-border-soft); background: linear-gradient(var(--l-card), var(--l-card-faint));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Fewer review cycles</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: var(--l-muted);\"><span class=\"sc-interp\">Mistakes are caught and fixed before the PR is even opened.</span></div>\n            </div>\n          </div>\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid var(--l-border-soft); background: linear-gradient(var(--l-card), var(--l-card-faint));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Standards enforced automatically</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: var(--l-muted);\"><span class=\"sc-interp\">Your conventions apply on every change without anyone policing them.</span></div>\n            </div>\n          </div>\n        \n          <div data-dc-tpl=\"458\" data-reveal=\"\" style=\"display: flex; gap: 15px; padding: 18px 20px; border-radius: 15px; border: 1px solid var(--l-border-soft); background: linear-gradient(var(--l-card), var(--l-card-faint));\">\n            <span data-dc-tpl=\"459\" style=\"flex-shrink: 0; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); display: flex; align-items: center; justify-content: center; color: rgb(251, 250, 255); font-weight: 700; font-size: 14px;\"><svg data-dc-tpl=\"460\" width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"461\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span>\n            <div data-dc-tpl=\"462\">\n              <div data-dc-tpl=\"463\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 16px; color: rgb(36, 29, 51);\"><span class=\"sc-interp\">Memory that compounds</span></div>\n              <div data-dc-tpl=\"464\" style=\"margin-top: 4px; font-size: 14px; line-height: 1.5; color: var(--l-muted);\"><span class=\"sc-interp\">Every decision captured makes the next one faster and safer.</span></div>\n            </div>\n          </div>\n        \n      </div>\n    </div>\n  </section>\n\n  \n  "}
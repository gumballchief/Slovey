{"html":"\n\n  <section data-dc-tpl=\"579\" id=\"cta\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 130px 24px 0px;\">\n    <div data-dc-tpl=\"580\" data-reveal=\"\" style=\"position: relative; border-radius: 28px; border: 1px solid rgba(255, 255, 255, 0.1); overflow: hidden; padding: clamp(40px, 6vw, 80px) 28px; text-align: center; background: linear-gradient(var(--l-card-strong), rgba(245, 243, 250, 0.86));\">\n      <div data-dc-tpl=\"581\" style=\"position: absolute; top: -30%; left: 50%; transform: translateX(-50%); width: 680px; height: 520px; background: radial-gradient(circle,var(--acc,var(--l-ink)),transparent 72%); opacity: 0.32;\"></div>\n      <div data-dc-tpl=\"582\" style=\"position: relative;\">\n        <h2 data-dc-tpl=\"583\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(32px, 5vw, 60px); line-height: 1.04; letter-spacing: -0.03em; margin: 0px auto; color: var(--l-ink); max-width: 20ch;\">Give your AI the context it's been missing</h2>\n        <p data-dc-tpl=\"584\" style=\"margin: 20px auto 0px; font-size: 18px; color: var(--l-muted); max-width: 52ch; line-height: 1.55;\">Connect a repository and watch Slovey start catching what your review process misses.</p>\n        <div data-dc-tpl=\"585\" style=\"display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 34px;\">\n          <a data-dc-tpl=\"586\" href=\"/login\" data-magnetic=\"\" style=\"font-size: 15.5px; font-weight: 600; color: var(--l-btn-text); text-decoration: none; padding: 15px 30px; border-radius: 13px; background: var(--l-btn); box-shadow: rgba(255, 120, 100, 0.8) 0px 16px 44px -16px;\">Start free</a>\n          <a data-dc-tpl=\"587\" href=\"/demo\" style=\"font-size: 15.5px; font-weight: 500; color: var(--l-body); text-decoration: none; padding: 15px 30px; border-radius: 13px; border: 1px solid var(--l-border-soft); background: var(--l-card);\">Book a demo</a>\n        </div>\n      </div>\n    </div>\n  </section>\n"}
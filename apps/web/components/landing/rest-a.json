{"html":"\n\n  \n  <section data-dc-tpl=\"271\" id=\"statement\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 140px 24px 120px;\">\n    <div data-dc-tpl=\"272\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7fb0f2);    \">The idea</div>\n    <div data-dc-tpl=\"273\" data-statement=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(28px, 4.8vw, 60px); line-height: 1.22; letter-spacing: -0.02em; margin-top: 26px; max-width: 20ch; color: rgba(27, 23, 38, 0.16);\">\n      <span data-dc-tpl=\"274\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">Company</span> <span data-dc-tpl=\"275\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">Brain</span> <span data-dc-tpl=\"276\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">gives</span> <span data-dc-tpl=\"277\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">every</span> <span data-dc-tpl=\"278\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">AI</span> <span data-dc-tpl=\"279\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">agent</span>\n      <span data-dc-tpl=\"280\" data-chip=\"\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 3px 12px 3px 5px; border-radius: 14px; background: rgba(255, 255, 255, 0.72); white-space: nowrap; vertical-align: middle;\"><span data-dc-tpl=\"281\" data-chip-icon=\"\" style=\"display: inline-flex; width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); color: rgb(36, 29, 51); align-items: center; justify-content: center; font-size: 16px; transform: scale(0); transition: transform 0.45s cubic-bezier(0.2, 1.5, 0.4, 1); box-shadow: none;\"><svg data-dc-tpl=\"282\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle data-dc-tpl=\"283\" cx=\"6\" cy=\"7.5\" r=\"2.1\"></circle><circle data-dc-tpl=\"284\" cx=\"18\" cy=\"7.5\" r=\"2.1\"></circle><circle data-dc-tpl=\"285\" cx=\"12\" cy=\"16.5\" r=\"2.1\"></circle><path data-dc-tpl=\"286\" d=\"M7.8 9.1 10.5 14.6\"></path><path data-dc-tpl=\"287\" d=\"M16.2 9.1 13.5 14.6\"></path><path data-dc-tpl=\"288\" d=\"M8.1 7.5h7.8\"></path></svg></span><span data-dc-tpl=\"289\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">your</span> <span data-dc-tpl=\"290\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">company's</span> <span data-dc-tpl=\"291\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">context</span></span><span data-dc-tpl=\"292\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">,</span>\n      <span data-dc-tpl=\"293\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">enforces</span> <span data-dc-tpl=\"294\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">your</span> <span data-dc-tpl=\"295\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">standards,</span> <span data-dc-tpl=\"296\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">remembers</span>\n      <span data-dc-tpl=\"297\" data-chip=\"\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 3px 12px 3px 5px; border-radius: 14px; background: rgba(255, 255, 255, 0.72); white-space: nowrap; vertical-align: middle;\"><span data-dc-tpl=\"298\" data-chip-icon=\"\" style=\"display: inline-flex; width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); color: rgb(36, 29, 51); align-items: center; justify-content: center; font-size: 16px; transform: scale(0); transition: transform 0.45s cubic-bezier(0.2, 1.5, 0.4, 1); box-shadow: none;\"><svg data-dc-tpl=\"299\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle data-dc-tpl=\"300\" cx=\"12\" cy=\"12\" r=\"8.4\"></circle><path data-dc-tpl=\"301\" d=\"M12 7.2v5l3.2 2\"></path></svg></span><span data-dc-tpl=\"302\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">past</span> <span data-dc-tpl=\"303\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">decisions</span></span><span data-dc-tpl=\"304\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">,</span>\n      <span data-dc-tpl=\"305\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">and</span> <span data-dc-tpl=\"306\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">stops</span> <span data-dc-tpl=\"307\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">mistakes</span>\n      <span data-dc-tpl=\"308\" data-chip=\"\" style=\"display: inline-flex; align-items: center; gap: 8px; padding: 3px 12px 3px 5px; border-radius: 14px; background: rgba(255, 255, 255, 0.72); white-space: nowrap; vertical-align: middle;\"><span data-dc-tpl=\"309\" data-chip-icon=\"\" style=\"display: inline-flex; width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(140deg,var(--acc,#4f7ef7),var(--acc2,#7fb0f2)); color: rgb(36, 29, 51); align-items: center; justify-content: center; font-size: 16px; transform: scale(0); transition: transform 0.45s cubic-bezier(0.2, 1.5, 0.4, 1); box-shadow: none;\"><svg data-dc-tpl=\"310\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fbfaff\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"311\" d=\"M5 12.5l4.5 4.5L19 7.5\"></path></svg></span><span data-dc-tpl=\"312\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">before</span> <span data-dc-tpl=\"313\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">they</span> <span data-dc-tpl=\"314\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">ship</span></span><span data-dc-tpl=\"315\" data-word=\"\" style=\"transition: color 0.35s; color: rgba(27, 23, 38, 0.16);\">.</span>\n    </div>\n  </section>\n\n  \n  <section data-dc-tpl=\"316\" id=\"problem\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 130px 24px 0px;\">\n    <div data-dc-tpl=\"317\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7fb0f2);\">01 — The problem</div>\n    <div data-dc-tpl=\"318\" style=\"display: grid; grid-template-columns: 1fr; gap: 12px; margin-top: 18px; max-width: 940px;\">\n      <h2 data-dc-tpl=\"319\" data-reveal=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.06; letter-spacing: -0.025em; margin: 0px; color: rgb(27, 23, 38);\">AI writes code. It doesn't know your company.</h2>\n      <p data-dc-tpl=\"320\" data-reveal=\"\" style=\"font-size: 18px; line-height: 1.55; color: rgb(86, 81, 99); max-width: 64ch; margin: 8px 0px 0px;\">Today's models are brilliant at syntax and shockingly ignorant of everything that actually makes your codebase <em data-dc-tpl=\"321\" style=\"font-style: normal; color: rgb(86, 81, 99);\">yours</em>. So they repeat the same mistakes — and engineers burn hours reviewing, fixing, and re-explaining.</p>\n    </div>\n    <div data-dc-tpl=\"322\" data-reveal=\"\" style=\"margin-top: 40px; display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 14px;\">\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Why past decisions were made</span></div>\n        </div>\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Which architectures were rejected</span></div>\n        </div>\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Your coding standards</span></div>\n        </div>\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Internal conventions</span></div>\n        </div>\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Past production incidents</span></div>\n        </div>\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Existing technical debt</span></div>\n        </div>\n      \n        <div data-dc-tpl=\"324\" style=\"padding: 18px; border-radius: 15px; border: 1px solid rgba(28, 20, 45, 0.07); background: linear-gradient(rgba(255, 255, 255, 0.7), rgba(255, 255, 255, 0.5));\">\n          <div data-dc-tpl=\"325\" style=\"display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(139, 150, 171); letter-spacing: 0.04em;\"><svg data-dc-tpl=\"326\" width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path data-dc-tpl=\"327\" d=\"M7 7l10 10M17 7L7 17\"></path></svg>doesn't know</div>\n          <div data-dc-tpl=\"328\" style=\"margin-top: 8px; font-size: 15.5px; font-weight: 500; color: rgb(86, 81, 99);\"><span class=\"sc-interp\">Real business constraints</span></div>\n        </div>\n      \n    </div>\n  </section>\n\n  \n  <section data-dc-tpl=\"329\" id=\"solution\" style=\"position: relative; z-index: 1; max-width: 1180px; margin: 0px auto; padding: 130px 24px 0px;\">\n    <div data-dc-tpl=\"330\" style=\"text-align: center; max-width: 820px; margin: 0px auto;\">\n      <div data-dc-tpl=\"331\" data-reveal=\"\" style=\"font-family: var(--font-mono), monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--acc2,#7fb0f2);\">02 — The solution</div>\n      <h2 data-dc-tpl=\"332\" data-reveal=\"\" style=\"font-family: var(--font-display), sans-serif; font-weight: 600; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.06; letter-spacing: -0.025em; margin: 16px 0px 0px; color: rgb(27, 23, 38);\">A permanent engineering memory for humans and AI</h2>\n      <p data-dc-tpl=\"333\" data-reveal=\"\" style=\"font-size: 18px; line-height: 1.55; color: rgb(86, 81, 99); margin: 16px auto 0px; max-width: 60ch;\">Instead of replacing Claude Code or Cursor, Company Brain sits <em data-dc-tpl=\"334\" style=\"font-style: normal; color: rgb(86, 81, 99);\">between</em> the agent and your repository — so every change is checked against how your company actually builds software.</p>\n    </div>\n\n    \n    <div data-dc-tpl=\"335\" data-reveal=\"\" data-flow=\"\" style=\"margin: 52px auto 0px; max-width: 980px; display: grid; grid-template-columns: 1fr auto 1.25fr auto 1fr; align-items: center; gap: 10px;\">\n      <div data-dc-tpl=\"336\" style=\"padding: 22px 18px; border-radius: 16px; border: 1px solid rgba(28, 20, 45, 0.08); background: rgba(255, 255, 255, 0.6); text-align: center;\">\n        <div data-dc-tpl=\"337\" style=\"font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(117, 112, 127); letter-spacing: 0.1em;\">AGENT</div>\n        <div data-dc-tpl=\"338\" style=\"margin-top: 8px; font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 17px; color: rgb(36, 29, 51);\">AI writes code</div>\n        <div data-dc-tpl=\"339\" style=\"margin-top: 4px; font-size: 12.5px; color: rgb(117, 112, 127);\">Claude Code · Cursor</div>\n      </div>\n      <div data-dc-tpl=\"340\" data-arrow=\"\" style=\"font-size: 22px; color: var(--acc,#4f7ef7);\">→</div>\n      <div data-dc-tpl=\"341\" style=\"position: relative; padding: 26px 20px; border-radius: 18px; border: 1px solid rgba(79, 126, 247, 0.4); background: linear-gradient(rgba(79, 126, 247, 0.16), rgba(127, 176, 242, 0.06)); text-align: center; box-shadow: 0 30px 80px -40px var(--acc,#4f7ef7);\">\n        <div data-dc-tpl=\"342\" style=\"position: absolute; inset: -1px; border-radius: 18px; border: 1px solid rgba(28, 20, 45, 0.1); pointer-events: none;\"></div>\n        <div data-dc-tpl=\"343\" style=\"display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-mono), monospace; font-size: 11px; color: var(--acc2,#7fb0f2); letter-spacing: 0.1em;\"><span data-dc-tpl=\"344\" style=\"width: 6px; height: 6px; border-radius: 50%; background: var(--acc2,#7fb0f2); box-shadow: 0 0 10px var(--acc2,#7fb0f2); animation: 2s ease-in-out 0s infinite normal none running cbPulse;\"></span>INTELLIGENCE LAYER</div>\n        <div data-dc-tpl=\"345\" style=\"margin-top: 8px; font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 19px; color: rgb(27, 23, 38);\">Company Brain</div>\n        <div data-dc-tpl=\"346\" style=\"margin-top: 4px; font-size: 13px; color: rgb(86, 81, 99);\">Reviews · enforces rules · remembers decisions</div>\n      </div>\n      <div data-dc-tpl=\"347\" data-arrow=\"\" style=\"font-size: 22px; color: var(--acc2,#7fb0f2);\">→</div>\n      <div data-dc-tpl=\"348\" style=\"padding: 22px 18px; border-radius: 16px; border: 1px solid rgba(28, 20, 45, 0.08); background: rgba(255, 255, 255, 0.6); text-align: center;\">\n        <div data-dc-tpl=\"349\" style=\"font-family: var(--font-mono), monospace; font-size: 11px; color: rgb(117, 112, 127); letter-spacing: 0.1em;\">REPO</div>\n        <div data-dc-tpl=\"350\" style=\"margin-top: 8px; font-family: var(--font-display), sans-serif; font-weight: 600; font-size: 17px; color: rgb(36, 29, 51);\">Clean, validated code</div>\n        <div data-dc-tpl=\"351\" style=\"margin-top: 4px; font-size: 12.5px; color: rgb(117, 112, 127);\">Only what passed</div>\n      </div>\n    </div>\n    <p data-dc-tpl=\"352\" data-reveal=\"\" style=\"text-align: center; margin: 26px auto 0px; max-width: 66ch; font-size: 15px; color: rgb(117, 112, 127);\">Everything it learns becomes a structured <strong data-dc-tpl=\"353\" style=\"color: rgb(86, 81, 99); font-weight: 600;\">Engineering Decision Graph</strong> — a living model of your architecture, standards, and history that both people and agents can query.</p>\n  </section>\n\n  \n  "}
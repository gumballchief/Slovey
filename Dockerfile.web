# Next.js dashboard. Build: docker build -f Dockerfile.web -t company-brain-web .
FROM node:22-slim AS base
# Node 22: pnpm 11 uses node:sqlite, which doesn't exist on Node 20 (install
# crashes with ERR_UNKNOWN_BUILTIN_MODULE). Update corepack so it can fetch the
# pinned pnpm, then enable it.
RUN npm install -g corepack@latest && corepack enable
WORKDIR /app

# --- deps (cached on manifest changes) ---
FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc ./
COPY packages/config/package.json packages/config/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/core/package.json packages/core/package.json
COPY apps/web/package.json apps/web/package.json
COPY apps/worker/package.json apps/worker/package.json
RUN pnpm install --frozen-lockfile

# --- build ---
FROM base AS build
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# NEXT_PUBLIC_* are inlined into the client bundle at build time, so they must be
# present during `next build` (there is no .env in the image). Render passes a
# service env var as a build arg when the Dockerfile declares a matching ARG.
ARG NEXT_PUBLIC_SUPABASE_URL
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL \
    NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
RUN pnpm --filter @company-brain/web build

# --- run (standalone: minimal server + only traced deps) ---
FROM base AS run
ENV NODE_ENV=production
# Standalone server defaults to binding localhost; bind all interfaces so the
# host (Render/Railway/Fly) can reach it. It reads $PORT automatically.
ENV HOSTNAME=0.0.0.0
WORKDIR /app
# Monorepo standalone layout: server.js lives at apps/web/server.js inside the
# standalone tree (rooted at the repo via outputFileTracingRoot).
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
